{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Braian Desktop",
  "version": "0.1.0",
  "identifier": "io.braian.desktop",
  "build": {
    "frontendDist": "../dist/client",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Braian Desktop",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "shadow": true,
        "center": true,
        "backgroundColor": "#0f1114"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
